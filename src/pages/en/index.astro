---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => {
		const aDate = a.data.pubDate || a.data.date || new Date();
		const bDate = b.data.pubDate || b.data.date || new Date();
		return bDate.valueOf() - aDate.valueOf();
	})
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-primary-950 text-slate-200">
		<Header />
		
		<!-- Hero Section -->
		<section class="relative overflow-hidden py-20 md:py-32">
			<!-- Background Glows -->
			<div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
			<div class="absolute top-1/3 left-1/3 w-[300px] h-[300px] bg-purple-500/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
			
			<div class="max-w-4xl mx-auto px-4 text-center">
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-900 border border-slate-800 text-xs font-semibold text-indigo-400 mb-6 uppercase tracking-wider">
					🚀 DevOps & Infrastructure Engineer
				</div>
				<h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-tight">
					Building Scalable, <br />
					<span class="text-gradient">Reliable Cloud Infrastructure</span>
				</h1>
				<p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
					Hello, I am Jeong-Yeol Cho. I design stable, efficient infrastructure architectures and build automation pipelines with a focus on Linux, Docker, AWS, and virtualization systems.
				</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a href="/en/blog" class="w-full sm:w-auto px-8 py-3 rounded-xl font-semibold bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500 text-white hover:opacity-95 transition-all shadow-lg shadow-indigo-500/25">
						Read Blog
					</a>
					<a href="/en/about" class="w-full sm:w-auto px-8 py-3 rounded-xl font-semibold bg-slate-900 border border-slate-800 text-slate-300 hover:text-white hover:bg-slate-800/60 transition-all">
						View Profile
					</a>
				</div>
			</div>
		</section>

		<!-- Tech & Focus Area Section -->
		<section class="py-16 border-t border-slate-900/60 bg-slate-950/20">
			<div class="max-w-6xl mx-auto px-4 md:px-8">
				<h2 class="text-2xl md:text-3xl font-bold text-center text-white mb-12 tracking-tight">Focus & Tech Stack</h2>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
					
					<!-- Card 1 -->
					<div class="glass p-6 rounded-2xl hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300">
						<div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 font-bold mb-4">🐧</div>
						<h3 class="text-lg font-semibold text-white mb-2">Linux & Shell</h3>
						<p class="text-sm text-slate-400 leading-relaxed">System kernel tuning, service optimization, and operational automation via Bash scripting.</p>
					</div>

					<!-- Card 2 -->
					<div class="glass p-6 rounded-2xl hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300">
						<div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center text-cyan-400 font-bold mb-4">🐳</div>
						<h3 class="text-lg font-semibold text-white mb-2">Docker & Container</h3>
						<p class="text-sm text-slate-400 leading-relaxed">Lightweight virtualization container design and stable service deployment in isolated environments.</p>
					</div>

					<!-- Card 3 -->
					<div class="glass p-6 rounded-2xl hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300">
						<div class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-400 font-bold mb-4">☁️</div>
						<h3 class="text-lg font-semibold text-white mb-2">AWS Cloud</h3>
						<p class="text-sm text-slate-400 leading-relaxed">High-availability multi-tier cloud infrastructure design and serverless/network optimization.</p>
					</div>

					<!-- Card 4 -->
					<div class="glass p-6 rounded-2xl hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300">
						<div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center text-purple-400 font-bold mb-4">⚙️</div>
						<h3 class="text-lg font-semibold text-white mb-2">DevOps & IaC</h3>
						<p class="text-sm text-slate-400 leading-relaxed">Infrastructure as Code (IaC) management using Terraform and integration of zero-downtime CI/CD pipelines.</p>
					</div>

				</div>
			</div>
		</section>

		<!-- Recent Posts Section -->
		<section class="py-20 border-t border-slate-900/60">
			<div class="max-w-4xl mx-auto px-4">
				<div class="flex items-center justify-between mb-10">
					<h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight">Recent Articles</h2>
					<a href="/blog" class="text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors">
						View All Articles &rarr;
					</a>
				</div>
				
				<div class="space-y-6">
					{
						posts.length > 0 ? (
							posts.map((post) => (
								<a href={`/blog/${post.id}/`} class="group block glass p-6 rounded-2xl hover:border-slate-800 transition-all duration-200">
									<div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-2">
										<h3 class="text-xl font-bold text-white group-hover:text-indigo-400 transition-colors">
											{post.data.title}
										</h3>
										<span class="text-xs text-slate-500 shrink-0">
											<FormattedDate date={post.data.pubDate || post.data.date || new Date()} />
										</span>
									</div>
									<p class="text-slate-400 text-sm leading-relaxed line-clamp-2">
										{post.data.description || 'No summary has been written for this post.'}
									</p>
								</a>
							))
						) : (
							<div class="glass p-8 rounded-2xl text-center text-slate-500">
								📝 No articles published yet. The first post will be coming soon!
							</div>
						)
					}
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
