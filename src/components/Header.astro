---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 glass border-b border-slate-800/50 transition-all duration-300">
	<nav class="max-w-6xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
		<h2 class="text-xl font-bold tracking-tight">
			<a href="/" class="hover:opacity-90 transition-opacity flex items-center gap-2">
				<span class="w-3 h-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 animate-pulse"></span>
				<span class="text-gradient">{SITE_TITLE}</span>
			</a>
		</h2>
		
		<div class="flex items-center gap-6 md:gap-8">
			<div class="flex items-center gap-1 md:gap-2">
				<HeaderLink href="/" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800/40 transition-all [&.active]:text-white [&.active]:bg-indigo-500/10 [&.active]:border border-indigo-500/20">Home</HeaderLink>
				<HeaderLink href="/blog" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800/40 transition-all [&.active]:text-white [&.active]:bg-indigo-500/10 [&.active]:border border-indigo-500/20">Blog</HeaderLink>
				<HeaderLink href="/about" class="px-3 py-1.5 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800/40 transition-all [&.active]:text-white [&.active]:bg-indigo-500/10 [&.active]:border border-indigo-500/20">About</HeaderLink>
			</div>
			
			<div class="h-4 w-px bg-slate-800 hidden sm:block"></div>
			
			<div class="hidden sm:flex items-center gap-4 text-slate-400">
				<a href="https://github.com/realx1017" target="_blank" class="hover:text-white transition-colors" aria-label="GitHub">
					<svg viewBox="0 0 16 16" fill="currentColor" width="20" height="20">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
				</a>
			</div>
		</div>
	</nav>
</header>
